# eBay API Credentials
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_AUTH_TOKEN=your_ebay_oauth_token_here

# Set to true to use eBay sandbox environment
EBAY_SANDBOX=false

# How often to scan for new deals (in minutes)
SCAN_INTERVAL_MINUTES=10

# Pushbullet API key for mobile push notifications
PUSHBULLET_API_KEY=your_pushbullet_api_key_here

# Minimum expected profit in dollars to consider a deal
MIN_PROFIT_THRESHOLD=20

# Path to the SQLite database file
DATABASE_PATH=./data/deals.db

# Logging level: debug, info, warn, error
LOG_LEVEL=info
