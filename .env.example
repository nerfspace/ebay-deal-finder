# eBay API credentials
# Get these from https://developer.ebay.com/my/keys
EBAY_APP_ID=your-ebay-app-id-here
EBAY_CERT_ID=your-ebay-cert-id-here
EBAY_AUTH_TOKEN=your-ebay-oauth-token-here
EBAY_SANDBOX=false

# Discord webhook for notifications
# Create a webhook in Discord: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Scan configuration
SCAN_INTERVAL_MINUTES=10
SEARCH_KEYWORDS=laptop,iPhone,iPad,MacBook,camera
SEARCH_CONDITION=USED
MIN_PRICE=20
MAX_PRICE=2000

# Deal filtering
MIN_PROFIT_THRESHOLD=20
MIN_TITLE_SIMILARITY=0.95
MIN_PROFIT_PERCENTAGE=25
SOLD_ITEMS_PER_CHECK=10
MAX_SOLD_CHECKS_PER_SCAN=100
EBAY_API_DELAY_MS=1500

# Database
DATABASE_PATH=./data/deals.db

# Logging
LOG_LEVEL=info

# Auction Source Scanning
AUCTION_SOURCES_ENABLED=true
AUCTION_MIN_TITLE_SIMILARITY=0.80
AUCTION_MIN_PROFIT_PCT=20

# Individual auction sources (set to false to disable)
SHOPGOODWILL_ENABLED=true
GOVDEALS_ENABLED=true
PROPERTYROOM_ENABLED=true
HERITAGE_ENABLED=true
BIDSPOTTER_ENABLED=true
